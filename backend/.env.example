# Server
PORT=5000
NODE_ENV=development

# CORS — comma separated list of allowed origins for the public registration API
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/wes

# Admin credentials (used for the admin dashboard login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d
